# ── Server ──────────────────────────────────────────────────────────
PORT=3001
BACKEND_URL=http://localhost:3001

# Secret for KeeperHub → backend internal webhooks (choose any random string)
INTERNAL_SECRET=change_me_to_a_random_secret

# ── Wallets ─────────────────────────────────────────────────────────
# Protocol wallet — owns phantom.eth on Sepolia, mints/burns ENS subnames + pays 0G gas
PROTOCOL_PRIVATE_KEY=0x...

# ── Ethereum / ENS (Sepolia testnet) ────────────────────────────────
ETH_RPC_URL=https://rpc.ankr.com/eth_sepolia
ENS_PARENT_NAME=phantom.eth
# ENS NameWrapper on Sepolia
ENS_NAME_WRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8

# ── 0G Network (Galileo Testnet, chain 16602) ───────────────────────
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_STORAGE_URL=https://indexer-storage-testnet-turbo.0g.ai



# ── KeeperHub ───────────────────────────────────────────────────────
KH_API_KEY=kh_...
# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/phantom
# ── Smart Contract (Sepolia) ────────────────────────────────────
# Deploy with: cd contracts && npm run deploy:sepolia
VAULT_CONTRACT_ADDRESS=0x...
VAULT_CHAIN_ID=11155111

# ── AXL (coordinator's own node) ────────────────────────────────────
COORDINATOR_AXL_API=http://127.0.0.1:9002

# ── E2E test vars (run-test.js) ─────────────────────────────────────
# Real Ed25519 AXL pubkeys for the seller and buyer test agents
# Obtain these from a running AXL node's peer registration
SELLER_AXL_PUBKEY=
BUYER_AXL_PUBKEY=
# Seller/buyer Ethereum addresses (optional — random fallback if not set)
SELLER_EPHEMERAL_ADDRESS=
BUYER_EPHEMERAL_ADDRESS=
# Real vault lock tx hash: buyer calls deposit() on VAULT_CONTRACT_ADDRESS
# and puts the resulting tx hash here before running the test
LOCK_TX_HASH=0x...
