# Sepolia RPC endpoint
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# Protocol wallet — must own ENS parent + have Sepolia ETH for gas
# Same key as backend/.env PROTOCOL_PRIVATE_KEY
PROTOCOL_PRIVATE_KEY=private_key

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Optional: override operator address (defaults to deployer)
OPERATOR_ADDRESS=

# Set to "true" to print gas usage during tests
REPORT_GAS=false
